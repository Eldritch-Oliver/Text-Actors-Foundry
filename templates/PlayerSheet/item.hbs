<li
	class="item"
	data-item-uuid="{{uuid}}"
>
	<div class="summary">
		<img
			src="{{img}}"
			alt=""
		>
		<div class="title">
			<span class="name">{{ name }}</span>
			<span class="subtitle">{{ weight }}</span>
		</div>
		<input
			type="number"
			value="{{quantity}}"
		>
		<button
			type="button"
			class="expand-button"
			data-action="toggleExpand"
			data-expanded="{{isExpanded}}"
			{{disabled (not canExpand)}}
		>
			<taf-icon
				name="icons/chevron"
				var:colour="var(--item-card-header-input-color)"
			></taf-icon>
		</button>
	</div>
	{{#if canExpand}}
		<div
			class="full-details"
			data-expanded="{{isExpanded}}"
		>
			{{{ description }}}
		</div>
	{{/if}}
</li>
